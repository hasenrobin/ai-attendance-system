# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Recognition worker secrets (SUPABASE_SERVICE_ROLE_KEY) — never commit.
recognition-worker/.env.worker

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

.env
*.env
node_modules/
dist/
camera-proxy/*.exe
*.tar.gz

# Installer build artefacts — binaries downloaded at build time, never committed.
installer/build/
installer/output/

# ONNX model files — large binary assets acquired separately per deployment.
# CHECKSUMS.sha256 IS committed (records expected hashes + download URLs).
# The .onnx binary files themselves are NOT committed.
# Acquisition: see docs/ai-models/AURAFACE_LICENSE_NOTES.md and
#              public/models/onnx/CHECKSUMS.sha256
#   scrfd.onnx    — SCRFD-10G-bnkps detector  (fal/AuraFace-v1, Apache-2.0, 16.9 MB)
#   auraface.onnx — AuraFace-v1 embedder      (fal/AuraFace-v1, Apache-2.0, 261 MB)
#   arcface.onnx  — ArcFace R50 embedder      (InsightFace, non-commercial research)
public/models/onnx/*.onnx

