# ============================================================
# AI Attendance — Local Customer Agent configuration
# Copy this file to .env.agent and fill in real values.
# .env.agent is gitignored — never commit real secrets.
# ============================================================

# Supabase project URL (same as VITE_SUPABASE_URL in the main app).
SUPABASE_URL=https://your-project.supabase.co

# Supabase service-role key (Project Settings → API → service_role).
# This key bypasses RLS so the agent can read discovery jobs and write results.
# NEVER expose this key to the browser or commit it to git.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# The company UUID this agent belongs to.
# Find it in the Supabase companies table or the app's Settings page.
AGENT_COMPANY_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Human-readable name for this agent (shown in the Cameras page).
AGENT_NAME=Main Office Agent

# Optional: restrict this agent to a specific branch UUID.
# Leave blank to allow it to handle jobs for the whole company.
AGENT_BRANCH_ID=

# ── Option A: Stream publishing to cloud MediaMTX ────────────────────────────
# RTSP endpoint on the cloud server where the agent pushes camera streams.
# Port 8554 must be open on the cloud server firewall.
MEDIAMTX_RTSP_PUBLISH_URL=rtsp://91.98.80.25:8554

# Public HLS base URL where the cloud MediaMTX serves HLS to browsers.
MEDIAMTX_HLS_PUBLIC_URL=http://91.98.80.25/camera-hls

# Path to ffmpeg binary on this machine.
# Linux: 'ffmpeg' (after apt install ffmpeg)
# Windows: full path, e.g. C:/ffmpeg/bin/ffmpeg.exe
FFMPEG_PATH=ffmpeg

# How often the agent polls for new discovery jobs (ms). Default: 5000.
AGENT_POLL_INTERVAL_MS=5000

# How often the agent sends a heartbeat to Supabase (ms). Default: 30000.
AGENT_HEARTBEAT_INTERVAL_MS=30000

# Maximum time allowed for a single discovery scan (ms). Default: 300000 (5 min).
AGENT_SCAN_TIMEOUT_MS=300000

# Maximum number of concurrent IPs to probe during a port scan. Default: 30.
AGENT_SCAN_CONCURRENCY=30
