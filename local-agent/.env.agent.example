# ============================================================
# AI Attendance - Local Customer Agent configuration
# Copy this file to .env.agent and fill in real values.
# .env.agent is gitignored - never commit real secrets.
# ============================================================

# Supabase project URL (same as VITE_SUPABASE_URL in the main app).
SUPABASE_URL=https://your-project.supabase.co

# Optional override. Defaults to <SUPABASE_URL>/functions/v1.
# AGENT_API_BASE_URL=https://your-project.supabase.co/functions/v1

# One-time pairing code generated from /admin/agents.
# Required only for first run. Remove after identity.json is created.
AGENT_PAIRING_CODE=

# Human-readable name shown in Platform Admin > Agents.
AGENT_NAME=Main Office Agent

# Agent API heartbeat.
AGENT_HEARTBEAT_INTERVAL_MS=30000

# Legacy discovery polling is disabled in Phase 3C until jobs move to Agent API.
# These values are kept for future use only.
# AGENT_POLL_INTERVAL_MS=5000
AGENT_SCAN_TIMEOUT_MS=300000
AGENT_SCAN_CONCURRENCY=30

# Local provisioning API.
# Keep 127.0.0.1 when opening /admin/cameras on the same machine.
# Use 0.0.0.0 only for trusted LAN tests.
PROVISIONING_API_HOST=127.0.0.1
PROVISIONING_API_PORT=8787

# Local MediaMTX/ffmpeg paths.
# Defaults point at ../camera-proxy in this repository.
# MEDIAMTX_DIR=../camera-proxy
# MEDIAMTX_YML_PATH=../camera-proxy/mediamtx.yml
# MEDIAMTX_EXECUTABLE=../camera-proxy/mediamtx.exe
# FFMPEG_PATH=../camera-proxy/ffmpeg.exe
# FFPROBE_PATH=../camera-proxy/ffprobe.exe
MEDIAMTX_AUTO_START=true

# Public HLS URL used as a browser fallback and provisioning health check.
# Default localhost means fallback Live View works from the agent machine only.
MEDIAMTX_HLS_PUBLIC_URL=http://localhost:8888

# Primary production stream path: Agent ffmpeg publishes SRT to cloud MediaMTX,
# and browsers play WebRTC/WHEP. Leave empty to use RTSP/HLS fallback only.
# SRT_PUBLISH_BASE_URL=srt://your-cloud-server:8890
# WEBRTC_PUBLIC_BASE_URL=https://your-cloud-domain/camera-webrtc

# Extra frontend origins allowed to call the local provisioning API.
# Example: CAMERA_PROXY_ALLOWED_ORIGINS=http://192.168.1.50:5173
CAMERA_PROXY_ALLOWED_ORIGINS=

# Secret for the POST /shutdown endpoint (X-Shutdown-Token header).
# Leave empty to disable /shutdown entirely (returns 404).
PROVISIONING_SHUTDOWN_SECRET=

# Cloud stream manager (legacy RTSP publish fallback). Disabled by default.
# Set to true and configure the URLs below only when explicitly using the
# older RTSP-to-HLS cloud path.
ENABLE_CLOUD_STREAM_MANAGER=false
# MEDIAMTX_RTSP_PUBLISH_URL=rtsp://your-cloud-server:8554
# MEDIAMTX_HLS_PUBLIC_URL=http://your-cloud-server/camera-hls

# ── Windows Service (PHASE 4A) ───────────────────────────────────────────────
# When running as a Windows Service via install-service.ps1, the agent
# directory is fixed (e.g. C:\AttendanceAI\local-agent). Set absolute paths
# so the service can find MediaMTX and ffmpeg regardless of working directory.
#
# Example for a typical installation:
#
# MEDIAMTX_DIR=C:\AttendanceAI\local-agent\bin
# MEDIAMTX_EXECUTABLE=C:\AttendanceAI\local-agent\bin\mediamtx.exe
# MEDIAMTX_YML_PATH=C:\AttendanceAI\local-agent\config\mediamtx.yml
# FFMPEG_PATH=C:\AttendanceAI\local-agent\bin\ffmpeg.exe
# FFPROBE_PATH=C:\AttendanceAI\local-agent\bin\ffprobe.exe
#
# Identity file location (default works without this):
# ATTENDANCEAI_IDENTITY_DIR=C:\ProgramData\AttendanceAI\Agent
#
# After the agent pairs once, remove AGENT_PAIRING_CODE from this file.
# The service will use identity.json on every subsequent restart.
