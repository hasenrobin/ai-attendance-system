# Copy this file to recognition-worker/.env.worker and fill in real values.
# .env.worker is gitignored — never commit real secrets.

# Supabase project URL (same value as VITE_SUPABASE_URL in the app's .env).
SUPABASE_URL=

# Supabase service role key (Project Settings -> API -> service_role key).
# This key bypasses Row Level Security so the worker can read every
# company's cameras/templates and write attendance/recognition events and
# recognition_worker_state. Keep it secret:
#   - never commit it
#   - never prefix it with VITE_ (Vite would bundle it into the browser build)
#   - never expose it to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Optional. faceapi | onnx_arcface (default: faceapi).
# onnx_arcface requires model files under public/models/onnx/ — see
# PRODUCTION_FACE_ENGINE_WORKER_REPORT.md. If the files are missing the
# worker fails honestly at startup with "Production model not configured".
FACE_ENGINE=faceapi

# Optional. How often (ms) the worker polls all companies/cameras. Default 10000.
WORKER_POLL_INTERVAL_MS=10000
